<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- NSPrivacyTracking: Veto does NOT track users across apps or websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- NSPrivacyTrackingDomains: No tracking domains used -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- NSPrivacyCollectedDataTypes: Veto collects NO user data -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- NSPrivacyAccessedAPITypes: Required API usage declarations -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- File timestamp APIs: used to check last sync time of blocklist binary file -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: Access file timestamps to manage App Group container sync state -->
                <string>C617.1</string>
            </array>
        </dict>
        <!-- UserDefaults: used to store sync timestamp and extension reload signal -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Access UserDefaults to store app-generated data (sync timestamps) -->
                <string>CA92.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
