<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- NSPrivacyTracking: Veto does NOT track users across apps or websites -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- NSPrivacyTrackingDomains: No tracking domains used -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- NSPrivacyCollectedDataTypes: Veto collects NO user data -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array/>

    <!-- NSPrivacyAccessedAPITypes: Required API usage declarations -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <!-- File timestamp APIs: used to check last sync time of blocklist binary file -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: Access file timestamps to manage App Group container sync state -->
                <string>C617.1</string>
            </array>
        </dict>

        <!-- UserDefaults: used to store sync timestamp, extension reload signal,
             and screened-calls store in the App Group container -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: Access UserDefaults to store app-generated data
                     (sync timestamps, screened call records, extension reload flags).
                     All data is app-generated and stored locally on the device only. -->
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- Speech Recognition: used for on-device voicemail transcription.
             SFSpeechRecognizer is configured with requiresOnDeviceRecognition = true.
             No audio or transcripts are sent to any server. -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategorySpeechRecognition</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- 1A: On-device speech recognition for app functionality
                     (voicemail transcription for Smart Voicemail Screening feature).
                     requiresOnDeviceRecognition is set to true; no data leaves the device. -->
                <string>1A</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
