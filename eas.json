{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_PROXY_URL": "https://api.vetospam.app"
      },
      "ios": {
        "simulator": false,
        "buildConfiguration": "Debug",
        "image": "macos-sonoma-14.6-xcode-16.0"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "remote",
      "env": {
        "EXPO_PUBLIC_PROXY_URL": "https://api.vetospam.app"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "macos-sonoma-14.6-xcode-16.0"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_PROXY_URL": "https://api.vetospam.app"
      },
      "ios": {
        "buildConfiguration": "Release",
        "image": "macos-sonoma-14.6-xcode-16.0"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "kcalvaresi@gmail.com",
        "ascAppId": "6759989634",
        "appleTeamId": "3D2Y23S825"
      }
    },
    "preview": {
      "ios": {
        "appleId": "kcalvaresi@gmail.com",
        "ascAppId": "6759989634",
        "appleTeamId": "3D2Y23S825"
      }
    }
  }
}
