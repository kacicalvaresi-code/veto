# ─── Veto Backend Proxy v2.0 — Environment Configuration ────────────────────

# Server
PORT=3000
NODE_ENV=production

# CORS — comma-separated list of allowed origins
# For native mobile apps you can leave this blank (no-origin requests are always allowed)
ALLOWED_ORIGINS=https://vetospam.app,http://localhost:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# ─── Optional: Call Control API (real-time reputation checks) ─────────────────
# Sign up at https://www.callcontrol.com/developers/
# If not set, the server falls back to a local binary-search against the spam list.
# CALL_CONTROL_API_KEY=your_call_control_api_key_here
